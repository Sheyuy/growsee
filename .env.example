# ============================================================
# 数据库配置 (PostgreSQL)
# ============================================================
# 选择以下其中一种方案:
#
# A. 本地开发 (Docker)
#    docker run -d --name growsee-postgres \
#      -e POSTGRES_PASSWORD=your_password \
#      -e POSTGRES_DB=growsee \
#      -p 5432:5432 postgres:16
#    DATABASE_URL=postgresql://postgres:your_password@localhost:5432/growsee
#
# B. 远程服务器 (tc-ts)
#    (需要在服务器上安装 PostgreSQL)
#    DATABASE_URL=postgresql://postgres:__YOUR_PASSWORD__@tc-ts_host:5432/growsee
#
# C. 免费托管方案 (Supabase / Neon / Fly.io)
#    Supabase: 免费 500MB, 提供连接字符串
#    Neon: 免费 500MB, 无服务器
#    DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
#
DATABASE_URL=postgresql://postgres:__YOUR_PASSWORD__@localhost:5432/growsee

# ============================================================
# MiniMax AI API (从 1Password → Clawbot/LLM_MiniMax_Official 获取)
# ============================================================
MINIMAX_API_KEY=sk-cp-Ps36TsgUDCA-1Cr7jB-gWL_QlJtUk6nERJgSlTLi4zjJdOhMSesKQnOydPaZJSX6GDqMyPym6MMJDyjzAimdxj-H1KFKEwwYEbXHQ7L9yqabIrlGjnQ5bOI
MINIMAX_GROUP_ID=

# ============================================================
# 文件存储 (Demo 阶段: 本地文件系统)
# ============================================================
# 零成本方案，图片保存在 public/uploads/ 下，通过 HTTP 直接访问
# 后续可替换为: R2 (免费 10GB/月) / 七牛云 (10GB 免费) / 又拍云
STORAGE_TYPE=local
UPLOAD_DIR=public/uploads
UPLOAD_BASE_URL=/uploads

# 如需切换到腾讯云 COS，取消下面注释并填写:
# STORAGE_TYPE=cos
# TENCENT_COS_SECRET_ID=__YOUR_COS_SECRET_ID__
# TENCENT_COS_SECRET_KEY=__YOUR_COS_SECRET_KEY__
# TENCENT_COS_BUCKET=__YOUR_BUCKET_NAME__
# TENCENT_COS_REGION=ap-shanghai

# ============================================================
# 微信小程序 (Demo 阶段可跳过，用 DEMO_MODE 替代)
# ============================================================
# 需要注册微信小程序获取
WECHAT_MINIAPP_ID=__YOUR_WECHAT_MINIAPP_ID__
WECHAT_MINIAPP_SECRET=__YOUR_WECHAT_MINIAPP_SECRET__

# ============================================================
# JWT 签名密钥 (必须配置)
# ============================================================
# 生成命令: openssl rand -hex 32
# 或运行: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=__GENERATE_A_64_CHAR_HEX_STRING__

# ============================================================
# 应用配置
# ============================================================
# 运行环境
development | production
NODE_ENV=development

# Demo 模式: true = 跳过真实微信登录，自动创建模拟用户
# 适合本地开发、对外展示，无需注册小程序
NEXT_PUBLIC_DEMO_MODE=true

# ============================================================
# 可选: 定时任务密钥
# ============================================================
CRON_SECRET=__ANY_RANDOM_STRING__
